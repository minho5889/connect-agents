# Copy to .env and fill in. Then: set -a; . ./.env; set +a
# (.env is gitignored.)

# AWS region of your Connect Customer instance.
#   us-east-1  -> full capability incl. Nova Sonic (sandbox / synthetic data)
#   ca-central-1 -> Canada-resident; no Nova Sonic; small model menu (see docs/03)
AWS_REGION=us-east-1

# The Amazon Q in Connect (qconnect) assistant ID for your instance.
# Find it in the Connect admin site / via: aws qconnect list-assistants
CONNECT_ASSISTANT_ID=REPLACE_WITH_ASSISTANT_ID

# The Connect instance ARN.
CONNECT_INSTANCE_ARN=arn:aws:connect:us-east-1:REPLACE_ACCOUNT:instance/REPLACE_INSTANCE_ID

# Optional overrides.
# ARIA_MODEL_ID=us.anthropic.claude-4-5-haiku-20251001-v1:0   # ca-central-1: see docs/03 §4
# ARIA_LOCALE=en_US
# ARIA_NAME_PREFIX=aria
